<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { min-height: 100vh; background: linear-gradient(135deg, #0f172a, #111827); color: #e5e7eb; }
    .card-glass { background: rgba(255,255,255,0.08); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.12); border-radius: 20px; }
  </style>
</head>
<body>
  <div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="col-12 col-md-10 col-lg-5">
      <div class="card card-glass text-white">
        <div class="card-body p-4 p-md-5">
          <h1 class="h4 fw-bold mb-3">Financial Suite</h1>
          <div class="d-flex gap-2 mb-3">
            <a href="/login" class="btn btn-sm <%= mode === 'login' ? 'btn-success' : 'btn-outline-light' %>">Login</a>
            <a href="/register" class="btn btn-sm <%= mode === 'register' ? 'btn-success' : 'btn-outline-light' %>">Register</a>
          </div>
          <div class="mb-3">
            <span class="badge text-bg-success">MongoDB: <%= mongoStatus %></span>
            <span class="badge text-bg-primary">Server: <%= serverStatus %></span>
          </div>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
          <% if (mode === 'register') { %>
            <form action="/register" method="POST" class="vstack gap-3">
              <input class="form-control form-control-lg" name="name" placeholder="Full Name" required>
              <input class="form-control form-control-lg" name="email" type="email" placeholder="Email" required>
              <input class="form-control form-control-lg" name="password" type="password" placeholder="Password" required>
              <button class="btn btn-success btn-lg" type="submit">Create Account</button>
            </form>
          <% } else { %>
            <form action="/login" method="POST" class="vstack gap-3">
              <input class="form-control form-control-lg" name="email" type="email" placeholder="Email" required>
              <input class="form-control form-control-lg" name="password" type="password" placeholder="Password" required>
              <button class="btn btn-success btn-lg" type="submit">Sign In</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

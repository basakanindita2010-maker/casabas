<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #111827 100%);
      color: #e5e7eb;
    }
    .card-glass {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 20px 60px rgba(0,0,0,0.35);
      border-radius: 20px;
    }
    .brand-badge {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #22c55e, #0ea5e9);
      font-weight: 700;
      color: white;
    }
    .text-muted-soft { color: rgba(255,255,255,0.7) !important; }
    .form-control {
      background: rgba(255,255,255,0.92);
    }
  </style>
</head>
<body>
  <div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="row w-100 justify-content-center">
      <div class="col-12 col-md-10 col-lg-5">
        <div class="card card-glass text-white">
          <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center gap-3 mb-4">
              <div class="brand-badge">FS</div>
              <div>
                <h1 class="h4 mb-1 fw-bold">Financial Suite</h1>
                <p class="mb-0 text-muted-soft">Secure access to your dashboard</p>
              </div>
            </div>

            <div class="d-flex gap-2 mb-4">
              <a href="/login" class="btn btn-sm <%= mode === 'login' ? 'btn-success' : 'btn-outline-light' %>">Login</a>
              <a href="/register" class="btn btn-sm <%= mode === 'register' ? 'btn-success' : 'btn-outline-light' %>">Register</a>
            </div>

            <div class="mb-3">
              <span class="badge text-bg-success">MongoDB: <%= mongoStatus %></span>
              <span class="badge text-bg-primary">Server: <%= serverStatus %></span>
            </div>

            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success"><%= success %></div>
            <% } %>

            <% if (mode === 'register') { %>
              <form action="/register" method="POST">
                <div class="mb-3">
                  <label class="form-label">Full Name</label>
                  <input type="text" class="form-control form-control-lg" name="name" required>
                </div>
                <div class="mb-3">
                  <label class="form-label">Email</label>
                  <input type="email" class="form-control form-control-lg" name="email" required>
                </div>
                <div class="mb-4">
                  <label class="form-label">Password</label>
                  <input type="password" class="form-control form-control-lg" name="password" required>
                </div>
                <button class="btn btn-success btn-lg w-100 fw-semibold" type="submit">Create Account</button>
              </form>
            <% } else { %>
              <form action="/login" method="POST">
                <div class="mb-3">
                  <label class="form-label">Email</label>
                  <input type="email" class="form-control form-control-lg" name="email" required>
                </div>
                <div class="mb-4">
                  <label class="form-label">Password</label>
                  <input type="password" class="form-control form-control-lg" name="password" required>
                </div>
                <button class="btn btn-success btn-lg w-100 fw-semibold" type="submit">Sign In</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

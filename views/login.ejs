<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #111827 100%);
      color: #e5e7eb;
    }
    .card-glass {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 20px 60px rgba(0,0,0,0.35);
      border-radius: 20px;
    }
    .brand-badge {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #22c55e, #0ea5e9);
      font-weight: 700;
      color: white;
    }
    .text-muted-soft {
      color: rgba(255,255,255,0.7) !important;
    }
    .form-control, .input-group-text {
      background: rgba(255,255,255,0.92);
    }
  </style>
</head>
<body>
  <div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="row w-100 justify-content-center">
      <div class="col-12 col-md-10 col-lg-5">
        <div class="card card-glass text-white">
          <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center gap-3 mb-4">
              <div class="brand-badge">FS</div>
              <div>
                <h1 class="h4 mb-1 fw-bold">Financial Suite</h1>
                <p class="mb-0 text-muted-soft">Secure access to your dashboard</p>
              </div>
            </div>

            <div class="mb-4">
              <div class="d-flex flex-wrap gap-2">
                <span class="badge text-bg-success">MongoDB: <%= mongoStatus %></span>
                <span class="badge text-bg-primary">Server: <%= serverStatus %></span>
              </div>
            </div>

            <% if (error) { %>
              <div class="alert alert-danger" role="alert"><%= error %></div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success" role="alert"><%= success %></div>
            <% } %>

            <form action="/login" method="POST" novalidate>
              <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  name="email"
                  placeholder="name@company.com"
                  required
                >
              </div>

              <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="password"
                  name="password"
                  placeholder="Enter your password"
                  required
                >
              </div>

              <button type="submit" class="btn btn-success btn-lg w-100 fw-semibold">
                Sign In
              </button>
            </form>

            <div class="mt-4 pt-3 border-top border-light border-opacity-25">
              <p class="small mb-0 text-muted-soft">
                Production-ready V1 with session authentication, bcrypt hashing, protected routes, and MongoDB Atlas support.
              </p>
            </div>
          </div>
        </div>

        <div class="text-center mt-3">
          <small class="text-muted-soft">
            © <%= new Date().getFullYear() %> Financial Suite
          </small>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

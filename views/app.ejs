<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    :root { --bg:#f8fafc; --panel:#fff; --border:#e2e8f0; --text:#0f172a; --muted:#64748b; --primary:#2563eb; --secondary:#0f766e; --danger:#dc2626; --success:#16a34a; --shadow:0 18px 50px rgba(15,23,42,0.08); }
    * { box-sizing:border-box; }
    body { margin:0; font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:linear-gradient(180deg,#eff6ff 0%,#f8fafc 20%,#f8fafc 100%); color:var(--text); }
    .topbar { position:sticky; top:0; z-index:20; background:rgba(255,255,255,0.82); backdrop-filter:blur(12px); border-bottom:1px solid rgba(226,232,240,0.9); }
    .topbar-inner { max-width:1600px; margin:0 auto; padding:16px 24px; display:flex; justify-content:space-between; gap:16px; align-items:center; flex-wrap:wrap; }
    .brand { display:flex; flex-direction:column; } .brand strong { font-size:22px; } .brand span { color:var(--muted); font-size:13px; }
    .userbox { display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
    .pill { padding:8px 12px; border-radius:999px; background:#eff6ff; border:1px solid #dbeafe; color:var(--primary); font-size:13px; font-weight:600; }
    .logout-btn { border:none; background:var(--danger); color:#fff; padding:10px 14px; border-radius:12px; cursor:pointer; font-weight:700; }
    .layout { max-width:1600px; margin:0 auto; padding:24px; display:grid; grid-template-columns:290px 1fr; gap:22px; }
    .sidebar,.content { background:var(--panel); border:1px solid var(--border); border-radius:24px; box-shadow:var(--shadow); }
    .sidebar { padding:20px; height:fit-content; position:sticky; top:92px; }
    .nav a { display:block; text-decoration:none; color:var(--text); padding:12px 14px; border-radius:14px; margin-bottom:8px; background:#f8fafc; font-weight:600; }
    .nav a.active { background:linear-gradient(135deg,#dbeafe,#dcfce7); border-color:#bfdbfe; }
    .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:18px; }
    .stat-card { background:var(--panel); border:1px solid var(--border); border-radius:20px; padding:18px; box-shadow:var(--shadow); }
    .stat-card span { color:var(--muted); font-size:13px; } .stat-card strong { display:block; margin-top:8px; font-size:26px; }
    .content { padding:22px; }
    h1,h2,h3 { margin-top:0; } h2 { font-size:26px; margin-bottom:8px; } .subtext { color:var(--muted); margin-bottom:18px; }
    .message { padding:14px 16px; border-radius:14px; margin-bottom:16px; font-size:14px; } .message.error { background:#fef2f2; border:1px solid #fecaca; color:#991b1b; } .message.success { background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; } .message.info { background:#eff6ff; border:1px solid #bfdbfe; color:#1d4ed8; }
    .panel { border:1px solid var(--border); border-radius:20px; padding:18px; background:#fff; }
    .timeline { display:grid; gap:10px; } .timeline-item { padding:14px; border-radius:14px; border:1px solid var(--border); background:#f8fafc; } .timeline-item small { color:var(--muted); }
    @media (max-width:1200px){ .layout{grid-template-columns:1fr;} .sidebar{position:static;} }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>Financial Suite SaaS</strong>
        <span>Professional reports, clients, documents, loan applications, and SME lending advisory</span>
      </div>
      <div class="userbox">
        <span class="pill">MongoDB: <%= mongoStatus %></span>
        <span class="pill">Server: <%= serverStatus %></span>
        <span class="pill">Logged in as: <%= user.name %> (<%= user.role %>)</span>
        <form method="POST" action="/logout" style="margin:0;"><button class="logout-btn" type="submit">Logout</button></form>
      </div>
    </div>
  </header>

  <main class="layout">
    <aside class="sidebar">
      <div class="nav">
        <a href="<%= navClientsUrl %>" class="<%= section === 'clients' ? 'active' : '' %>">Clients</a>
        <a href="<%= navUsersUrl %>" class="<%= section === 'users' ? 'active' : '' %>">Users</a>
        <a href="<%= navAuditUrl %>" class="<%= section === 'audit' ? 'active' : '' %>">Audit Logs</a>
        <a href="<%= navDocumentsUrl %>" class="<%= section === 'documents' ? 'active' : '' %>">Documents</a>
        <a href="<%= navFinanceUrl %>" class="<%= section === 'finance' ? 'active' : '' %>">Finance</a>
        <a href="<%= navLoansUrl %>" class="<%= section === 'loans' ? 'active' : '' %>">Loans</a>
        <a href="<%= navAdvisoryUrl %>" class="<%= section === 'advisory' ? 'active' : '' %>">SME Advisory</a>
      </div>
    </aside>

    <section class="content">
      <% if (error) { %><div class="message error"><%= error %></div><% } %>
      <% if (success) { %><div class="message success"><%= success %></div><% } %>

      <div class="stats-grid">
        <div class="stat-card"><span>Total Users</span><strong><%= stats.totalUsers %></strong></div>
        <div class="stat-card"><span>Total Clients</span><strong><%= stats.totalClients %></strong></div>
        <div class="stat-card"><span>Total Documents</span><strong><%= stats.totalDocuments %></strong></div>
        <div class="stat-card"><span>Total Loan Apps</span><strong><%= loanApplications ? loanApplications.length : 0 %></strong></div>
      </div>

      <% if (section === 'advisory') { %>
        <div class="panel">
          <h2>SME Lending Advisory Suite</h2>
          <div class="subtext">Generate lender comparison matrix, credit memo, proposal packs, and batch ZIP downloads.</div>

          <div class="panel">
            <h3>Batch ZIP Download</h3>
            <a href="/advisory/export-batch.zip" target="_blank">Download Batch ZIP Package</a>
          </div>

          <div class="panel" style="margin-top:18px;">
            <h3>Lender Comparison Matrix</h3>
            <table>
              <thead>
                <tr>
                  <th>Business</th>
                  <th>Readiness</th>
                  <th>Lender</th>
                  <th>Score</th>
                  <th>DSCR Threshold</th>
                  <th>Fit</th>
                  <th>Verdict</th>
                </tr>
              </thead>
              <tbody>
                <% advisories.forEach((a) => { const rows = a.lenderMatrix || []; rows.forEach((b, idx) => { %>
                  <tr>
                    <% if (idx === 0) { %>
                      <td rowspan="<%= rows.length %>"><strong><%= a.businessName %></strong><br /><small><%= a.industry %></small></td>
                      <td rowspan="<%= rows.length %>"><%= a.readiness.score %>/100<br /><%= a.readiness.band %></td>
                    <% } %>
                    <td><%= b.bankName %></td>
                    <td><%= b.score %></td>
                    <td><%= b.dscrThreshold %></td>
                    <td><%= b.fit %></td>
                    <td><%= b.verdict %></td>
                  </tr>
                <% }) }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

      <div class="panel" style="margin-top:18px;">
        <h3>Recent Activity Feed</h3>
        <div class="timeline">
          <% combinedFeed.forEach((item) => { %>
            <div class="timeline-item">
              <strong><%= item.kind.toUpperCase() %></strong> - <%= item.text %>
              <br />
              <small><%= new Date(item.at).toLocaleString() %></small>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
  </main>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f8fafc; }
    .topnav { position: sticky; top: 0; z-index: 1030; background: #fff; border-bottom: 1px solid #e5e7eb; }
    .sidebar { background: linear-gradient(180deg, #0f172a, #111827); color: #fff; min-height: calc(100vh - 64px); }
    .stat-card, .panel-card { border: 0; box-shadow: 0 12px 30px rgba(15,23,42,0.08); border-radius: 18px; }
    .toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 2000; }
    .doc-card { transition: .2s; }
    .doc-card:hover { transform: translateY(-2px); }
  </style>
</head>
<body>
  <div class="toast-container">
    <% if (toast) { %>
      <div class="toast show align-items-center text-bg-<%= toast.type === 'success' ? 'success' : 'primary' %> border-0" role="alert">
        <div class="d-flex">
          <div class="toast-body"><%= toast.message %></div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
      </div>
    <% } %>
  </div>

  <nav class="topnav navbar navbar-expand-lg navbar-light px-3">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/app?section=clients">Financial Suite</a>
      <div class="d-flex align-items-center gap-2 ms-auto flex-wrap">
        <span class="badge text-bg-light border text-dark">Users: <%= stats.totalUsers %></span>
        <span class="badge text-bg-light border text-dark">Clients: <%= stats.totalClients %></span>
        <span class="badge text-bg-light border text-dark">Documents: <%= stats.totalDocuments %></span>
        <span class="badge text-bg-light border text-dark">Statements: <%= stats.totalStatements %></span>
        <span class="badge text-bg-light border text-dark">Logs: <%= stats.totalAuditLogs %></span>
        <form action="/logout" method="POST" class="ms-2"><button class="btn btn-sm btn-outline-danger" type="submit">Logout</button></form>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <aside class="col-12 col-lg-3 col-xl-2 sidebar p-4">
        <div class="mb-3">
          <div class="small text-white-50">Signed in as</div>
          <div class="fw-semibold"><%= user.name %></div>
          <div class="small text-white-50"><%= user.email %></div>
          <div class="small text-white-50">Role: <%= user.role %></div>
        </div>
        <div class="d-grid gap-2">
          <a class="btn btn-outline-light" href="/app?section=clients">Clients</a>
          <a class="btn btn-outline-light" href="/app?section=documents">Documents</a>
          <a class="btn btn-outline-light" href="/app?section=finance">Finance</a>
          <% if (user.role === 'admin') { %>
            <a class="btn btn-outline-light" href="/app?section=users">Users</a>
            <a class="btn btn-outline-light" href="/app?section=audit">Audit Logs</a>
          <% } %>
        </div>
      </aside>

      <main class="col-12 col-lg-9 col-xl-10 p-0">
        <div class="p-3 p-md-4">
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

          <div class="row g-3 mb-4">
            <div class="col-md-3"><div class="card stat-card"><div class="card-body p-4"><div class="text-muted small">MongoDB Status</div><div class="h4 mb-0 <%= mongoStatus === 'Connected' ? 'text-success' : 'text-danger' %>"><%= mongoStatus %></div></div></div></div>
            <div class="col-md-3"><div class="card stat-card"><div class="card-body p-4"><div class="text-muted small">Server Status</div><div class="h4 mb-0 text-primary"><%= serverStatus %></div></div></div></div>
            <div class="col-md-2"><div class="card stat-card"><div class="card-body p-4"><div class="text-muted small">Documents</div><div class="h4 mb-0 text-warning"><%= stats.totalDocuments %></div></div></div></div>
            <div class="col-md-2"><div class="card stat-card"><div class="card-body p-4"><div class="text-muted small">Statements</div><div class="h4 mb-0 text-success"><%= stats.totalStatements %></div></div></div></div>
            <div class="col-md-2"><div class="card stat-card"><div class="card-body p-4"><div class="text-muted small">Activities</div><div class="h4 mb-0 text-dark"><%= stats.totalActivities %></div></div></div></div>
          </div>

          <% if (section === 'finance') { %>
            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <h3 class="h5 mb-3">Statement Upload Cards</h3>
                <div class="row g-3">
                  <div class="col-12 col-md-4"><div class="card h-100 border-0 shadow-sm rounded-4"><div class="card-body"><h4 class="h6">Balance Sheet</h4><p class="small text-muted">Store assets, liabilities, equity and ratios.</p></div></div></div>
                  <div class="col-12 col-md-4"><div class="card h-100 border-0 shadow-sm rounded-4"><div class="card-body"><h4 class="h6">Profit & Loss</h4><p class="small text-muted">Store revenue, expenses, EBITDA and EPS.</p></div></div></div>
                  <div class="col-12 col-md-4"><div class="card h-100 border-0 shadow-sm rounded-4"><div class="card-body"><h4 class="h6">Cash Flow</h4><p class="small text-muted">Store operating, investing and financing flow.</p></div></div></div>
                </div>
              </div>
            </div>

            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <h3 class="h5 mb-3">Financial Statement Upload</h3>
                <form action="/financial-statements" method="POST" class="row g-3">
                  <div class="col-md-4">
                    <select class="form-select" name="statementType" required>
                      <option>Balance Sheet</option>
                      <option>Profit & Loss</option>
                      <option>Cash Flow</option>
                    </select>
                  </div>
                  <div class="col-md-2"><input class="form-control" name="year" type="number" placeholder="Year" required></div>
                  <div class="col-md-3"><input class="form-control" name="previousYearData" placeholder='Previous Year Data JSON'></div>
                  <div class="col-md-3"><input class="form-control" name="data" placeholder='Current Data JSON'></div>
                  <div class="col-12"><button class="btn btn-success" type="submit">Save Statement</button></div>
                </form>
              </div>
            </div>

            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                  <h3 class="h5 mb-0">Financial Statements</h3>
                  <form method="GET" action="/app" class="d-flex gap-2 flex-wrap">
                    <input type="hidden" name="section" value="finance">
                    <input class="form-control" name="fsQ" value="<%= fsQuery || '' %>" placeholder="Search statements">
                    <select class="form-select" name="fsType">
                      <option value="">All Types</option>
                      <option value="Balance Sheet" <%= fsType === 'Balance Sheet' ? 'selected' : '' %>>Balance Sheet</option>
                      <option value="Profit & Loss" <%= fsType === 'Profit & Loss' ? 'selected' : '' %>>Profit & Loss</option>
                      <option value="Cash Flow" <%= fsType === 'Cash Flow' ? 'selected' : '' %>>Cash Flow</option>
                    </select>
                    <input class="form-control" name="fsHistory" value="<%= fsHistory || '' %>" placeholder="History filter">
                    <button class="btn btn-outline-primary" type="submit">Filter</button>
                  </form>
                </div>

                <div class="row g-3">
                  <% financialStatements.forEach(function(stmt) { %>
                    <div class="col-12 col-md-6 col-xl-4">
                      <div class="card doc-card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body">
                          <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                              <h4 class="h6 mb-1"><%= stmt.statementType %></h4>
                              <div class="text-muted small">Year: <%= stmt.year %></div>
                            </div>
                            <span class="badge text-bg-light border text-dark"><%= (stmt.history || []).length %> history</span>
                          </div>

                          <div class="mb-3">
                            <strong>Computed Ratios</strong>
                            <pre class="small bg-light p-2 rounded-3 mb-0"><%= JSON.stringify(stmt.computedRatios || {}, null, 2) %></pre>
                          </div>

                          <div class="mb-3">
                            <strong>Recommendations</strong>
                            <ul class="small mb-0">
                              <% (recommendations || []).forEach(function(rec) { %>
                                <li><%= rec %></li>
                              <% }) %>
                            </ul>
                          </div>

                          <div class="mb-3">
                            <strong>Analysis</strong>
                            <ul class="small mb-0">
                              <% (analysis || []).forEach(function(a) { %>
                                <li><%= a %></li>
                              <% }) %>
                            </ul>
                          </div>

                          <div class="mb-3">
                            <strong>Previous Year Data</strong>
                            <pre class="small bg-light p-2 rounded-3 mb-0"><%= JSON.stringify(stmt.previousYearData || {}, null, 2) %></pre>
                          </div>

                          <div class="mb-3">
                            <strong>Current Data</strong>
                            <pre class="small bg-light p-2 rounded-3 mb-0"><%= JSON.stringify(stmt.data || {}, null, 2) %></pre>
                          </div>

                          <form action="/financial-statements/<%= stmt._id %>/recalculate" method="POST" class="row g-2 mb-3">
                            <div class="col-12"><input class="form-control form-control-sm" name="notes" placeholder="Reason for recalculation"></div>
                            <div class="col-12"><textarea class="form-control form-control-sm" name="previousYearData" placeholder="Previous Year Data JSON"><%= JSON.stringify(stmt.previousYearData || {}) %></textarea></div>
                            <div class="col-12"><textarea class="form-control form-control-sm" name="data" placeholder="Current Data JSON"><%= JSON.stringify(stmt.data || {}) %></textarea></div>
                            <div class="col-12"><button class="btn btn-sm btn-outline-primary" type="submit">Recalculate Ratios</button></div>
                          </form>

                          <form action="/financial-statements/<%= stmt._id %>/history" method="POST" class="mt-3">
                            <input class="form-control form-control-sm mb-2" name="notes" placeholder="Add history note">
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Add History Note</button>
                          </form>

                          <div class="mt-3">
                            <h6 class="small mb-2">History</h6>
                            <% (stmt.history || []).slice().reverse().forEach(function(h) { %>
                              <% if (!fsHistory || (h.notes && h.notes.toLowerCase().includes(fsHistory.toLowerCase()))) { %>
                                <div class="small border-bottom pb-2 mb-2">
                                  <div><strong><%= h.action %></strong> — <%= h.notes %></div>
                                  <div class="text-muted"><%= h.by %> at <%= new Date(h.at).toLocaleString() %></div>
                                </div>
                              <% } %>
                            <% }) %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          <% } else if (section === 'documents') { %>
            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <h3 class="h5 mb-3">Upload Document with File Reference</h3>
                <form action="/documents/upload" method="POST" enctype="multipart/form-data" class="row g-3">
                  <div class="col-md-4"><input class="form-control" name="title" placeholder="Document Title" required></div>
                  <div class="col-md-4"><input class="form-control" name="category" placeholder="Category" required></div>
                  <div class="col-md-4"><input class="form-control" name="clientName" placeholder="Client Name"></div>
                  <div class="col-12"><input class="form-control" name="description" placeholder="Description"></div>
                  <div class="col-md-8"><input class="form-control" name="file" type="file" accept=".pdf,.png,.jpg,.jpeg,.txt,.doc,.docx"></div>
                  <div class="col-md-4"><button class="btn btn-success w-100" type="submit">Upload</button></div>
                </form>
              </div>
            </div>

            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                  <h3 class="h5 mb-0">Document Library</h3>
                  <form method="GET" action="/app" class="d-flex gap-2 flex-wrap">
                    <input type="hidden" name="section" value="documents">
                    <input class="form-control" name="docQ" value="<%= req.query.docQ || '' %>" placeholder="Search documents">
                    <input class="form-control" name="docCategory" value="<%= req.query.docCategory || '' %>" placeholder="Category">
                    <input class="form-control" name="docOwner" value="<%= docOwnerFilter || '' %>" placeholder="Owner email">
                    <button class="btn btn-outline-primary" type="submit">Search</button>
                  </form>
                </div>

                <div class="row g-3">
                  <% documents.forEach(function(doc) { %>
                    <div class="col-12 col-md-6 col-xl-4">
                      <div class="card doc-card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body">
                          <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                              <h4 class="h6 mb-1"><%= doc.title %></h4>
                              <div class="text-muted small"><%= doc.category %></div>
                            </div>
                            <span class="badge text-bg-light border text-dark"><%= doc.downloadCount || 0 %> downloads</span>
                          </div>
                          <p class="small text-muted mb-2"><%= doc.description || 'No description' %></p>
                          <p class="small mb-1"><strong>Client:</strong> <%= doc.clientName || '-' %></p>
                          <p class="small mb-1"><strong>Uploaded By:</strong> <%= doc.uploadedBy || '-' %></p>
                          <p class="small mb-1"><strong>Storage:</strong> <%= doc.storageRef || '-' %></p>
                          <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-sm btn-outline-primary" href="/documents/<%= doc._id %>/download">Download</a>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#editDoc<%= doc._id %>">Edit</button>
                            <form action="/documents/<%= doc._id %>/delete" method="POST" onsubmit="return confirm('Delete this document?')">
                              <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                            </form>
                          </div>
                          <div class="collapse mt-3" id="editDoc<%= doc._id %>">
                            <form action="/documents/<%= doc._id %>/edit" method="POST" enctype="multipart/form-data" class="row g-2">
                              <div class="col-12"><input class="form-control form-control-sm" name="title" value="<%= doc.title %>" required></div>
                              <div class="col-12"><input class="form-control form-control-sm" name="category" value="<%= doc.category %>" required></div>
                              <div class="col-12"><input class="form-control form-control-sm" name="clientName" value="<%= doc.clientName %>" placeholder="Client Name"></div>
                              <div class="col-12"><input class="form-control form-control-sm" name="description" value="<%= doc.description %>" placeholder="Description"></div>
                              <div class="col-12"><input class="form-control form-control-sm" name="file" type="file" accept=".pdf,.png,.jpg,.jpeg,.txt,.doc,.docx"></div>
                              <div class="col-12"><button class="btn btn-sm btn-primary" type="submit">Update</button></div>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>

                <div class="mt-4">
                  <h6>Per-Document Activity Filter</h6>
                  <form method="GET" action="/app" class="d-flex gap-2 flex-wrap mb-3">
                    <input type="hidden" name="section" value="documents">
                    <input class="form-control" name="docActivity" value="<%= docActivityFilter || '' %>" placeholder="uploaded / downloaded / updated / deleted">
                    <button class="btn btn-outline-primary" type="submit">Filter History</button>
                  </form>
                </div>

                <div class="mt-3">
                  <h6>Document Activity Timeline</h6>
                  <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                      <thead><tr><th>Time</th><th>Action</th><th>Performed By</th><th>Details</th></tr></thead>
                      <tbody>
                        <% documentTimeline.forEach(function(h) { %>
                          <tr>
                            <td class="text-nowrap"><%= new Date(h.createdAt).toLocaleString() %></td>
                            <td><%= h.action %></td>
                            <td><%= h.performedBy %></td>
                            <td><%= h.details %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          <% } else if (section === 'clients') { %>
            <div class="card panel-card mb-4">
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                  <h3 class="h5 mb-0">Add Client</h3>
                  <div>
                    <span class="badge text-bg-success me-1">Active: <%= stats.activeClients %></span>
                    <span class="badge text-bg-secondary">Inactive: <%= stats.inactiveClients %></span>
                  </div>
                </div>
                <form action="/clients" method="POST" class="row g-3">
                  <div class="col-md-3"><input class="form-control" name="clientName" placeholder="Client Name" required></div>
                  <div class="col-md-3"><input class="form-control" name="companyName" placeholder="Company Name" required></div>
                  <div class="col-md-2"><input class="form-control" name="email" type="email" placeholder="Email" required></div>
                  <div class="col-md-2"><input class="form-control" name="phone" placeholder="Phone" required></div>
                  <div class="col-md-2"><select class="form-select" name="status"><option>Active</option><option>Inactive</option></select></div>
                  <div class="col-12"><textarea class="form-control" name="address" placeholder="Address" required></textarea></div>
                  <div class="col-12"><textarea class="form-control" name="notes" placeholder="Client Notes"></textarea></div>
                  <div class="col-12"><input class="form-control" name="tags" placeholder="Tags comma separated e.g. vip,priority,retainer"></div>
                  <div class="col-12"><button class="btn btn-success" type="submit">Save Client</button></div>
                </form>
              </div>
            </div>
          <% } %>

          <div class="card panel-card mb-4">
            <div class="card-body p-4">
              <h3 class="h5 mb-3">Client / Document Combined Activity Feed</h3>
              <div class="list-group">
                <% combinedFeed.forEach(function(item) { %>
                  <div class="list-group-item d-flex justify-content-between align-items-start">
                    <div>
                      <div class="fw-semibold"><%= item.text %></div>
                      <div class="small text-muted"><%= item.kind %></div>
                    </div>
                    <div class="small text-muted text-nowrap"><%= new Date(item.at).toLocaleString() %></div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</body>
</html>

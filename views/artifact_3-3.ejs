<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    :root {
      --bg:#0f172a;
      --card:rgba(255,255,255,0.08);
      --card-border:rgba(255,255,255,0.14);
      --text:#e2e8f0;
      --muted:#94a3b8;
      --input:rgba(15,23,42,0.7);
    }
    * { box-sizing:border-box; }
    body {
      margin:0;
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      background:radial-gradient(circle at top, #1d4ed8 0%, #0f172a 35%, #020617 100%);
      color:var(--text);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .wrap {
      width:100%;
      max-width:980px;
      display:grid;
      grid-template-columns:1.1fr 0.9fr;
      gap:24px;
    }
    .hero,.card {
      background:var(--card);
      border:1px solid var(--card-border);
      backdrop-filter:blur(18px);
      border-radius:24px;
      box-shadow:0 20px 80px rgba(0,0,0,0.35);
    }
    .hero {
      padding:40px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      min-height:620px;
    }
    .hero h1 {
      margin:0 0 12px;
      font-size:44px;
      line-height:1.05;
    }
    .hero p {
      color:var(--muted);
      line-height:1.7;
      max-width:520px;
      font-size:16px;
    }
    .badge {
      display:inline-flex;
      width:fit-content;
      gap:8px;
      align-items:center;
      padding:10px 14px;
      border-radius:999px;
      background:rgba(56,189,248,0.12);
      color:#7dd3fc;
      border:1px solid rgba(56,189,248,0.22);
      font-size:13px;
      margin-bottom:18px;
    }
    .stats {
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:12px;
      margin-top:28px;
    }
    .stat {
      padding:16px;
      border-radius:16px;
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
    }
    .stat strong {
      display:block;
      font-size:20px;
      margin-bottom:6px;
    }
    .stat span { color:var(--muted); font-size:13px; }
    .card {
      padding:28px;
      min-height:620px;
      display:flex;
      flex-direction:column;
      justify-content:center;
    }
    .tabs {
      display:flex;
      gap:10px;
      margin-bottom:22px;
    }
    .tab {
      flex:1;
      text-align:center;
      padding:12px 14px;
      border-radius:14px;
      text-decoration:none;
      color:var(--text);
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.08);
    }
    .tab.active {
      background:linear-gradient(135deg, rgba(56,189,248,0.25), rgba(34,197,94,0.18));
      border-color:rgba(56,189,248,0.28);
    }
    h2 { margin:0 0 8px; font-size:30px; }
    .sub { margin:0 0 24px; color:var(--muted); line-height:1.6; }
    .alert {
      padding:14px 16px;
      border-radius:14px;
      margin-bottom:16px;
      font-size:14px;
    }
    .alert.error {
      background:rgba(251,113,133,0.12);
      border:1px solid rgba(251,113,133,0.22);
      color:#fecdd3;
    }
    .alert.success {
      background:rgba(34,197,94,0.12);
      border:1px solid rgba(34,197,94,0.22);
      color:#bbf7d0;
    }
    label {
      display:block;
      margin-bottom:8px;
      color:#cbd5e1;
      font-size:14px;
    }
    input {
      width:100%;
      padding:14px 16px;
      border-radius:14px;
      background:var(--input);
      border:1px solid rgba(148,163,184,0.25);
      color:#fff;
      outline:none;
      margin-bottom:18px;
    }
    button {
      width:100%;
      padding:14px 16px;
      border:none;
      border-radius:14px;
      background:linear-gradient(135deg,#38bdf8,#22c55e);
      color:#04111f;
      font-weight:800;
      font-size:15px;
      cursor:pointer;
    }
    .meta {
      display:flex;
      justify-content:space-between;
      gap:12px;
      margin-top:18px;
      font-size:13px;
      color:var(--muted);
      flex-wrap:wrap;
    }
    .meta strong { color:#fff; }
    .footer-note {
      margin-top:18px;
      font-size:12px;
      color:var(--muted);
      line-height:1.6;
    }
    @media (max-width:900px){
      .wrap{grid-template-columns:1fr;}
      .hero,.card{min-height:auto;}
      .hero h1{font-size:36px;}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div>
        <div class="badge">Financial Suite SaaS</div>
        <h1>AI-powered SME lending advisory made simple.</h1>
        <p>Manage clients, documents, loan applications, lender comparisons, credit memos, and advisory packs in one secure dashboard. Generate PDF, XLSX, and ZIP batch exports.</p>
        <div class="stats">
          <div class="stat"><strong>Secure</strong><span>Session-based access</span></div>
          <div class="stat"><strong>Smart</strong><span>OpenAI-assisted insights</span></div>
          <div class="stat"><strong>Advisory Ready</strong><span>Excel + PDF output</span></div>
        </div>
      </div>
      <div class="footer-note">
        <strong>Server Status:</strong> <%= serverStatus %> &nbsp;|&nbsp;
        <strong>MongoDB:</strong> <%= mongoStatus %><br />
        Built for consultants, finance teams, and business owners.
      </div>
    </section>

    <section class="card">
      <div class="tabs">
        <a class="tab <%= mode === 'login' ? 'active' : '' %>" href="/login">Login</a>
        <a class="tab <%= mode === 'register' ? 'active' : '' %>" href="/register">Register</a>
      </div>

      <% if (error) { %><div class="alert error"><%= error %></div><% } %>
      <% if (success) { %><div class="alert success"><%= success %></div><% } %>

      <% if (mode === 'register') { %>
        <h2>Create Account</h2>
        <p class="sub">Register to access the financial dashboard and advisory suite.</p>
        <form method="POST" action="/register">
          <label for="name">Full Name</label>
          <input id="name" name="name" type="text" required />

          <label for="email">Email Address</label>
          <input id="email" name="email" type="email" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <button type="submit">Register</button>
        </form>
      <% } else { %>
        <h2>Welcome Back</h2>
        <p class="sub">Sign in to continue to your dashboard and advisory reports.</p>
        <form method="POST" action="/login">
          <label for="email">Email Address</label>
          <input id="email" name="email" type="email" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <button type="submit">Login</button>
        </form>
      <% } %>

      <div class="meta">
        <span><strong>Default Admin:</strong> admin@example.com</span>
        <span><strong>Password:</strong> NewAdmin@12345</span>
      </div>
    </section>
  </div>
</body>
</html>